   1          //DS18B20.c
   2          
   3          #include <STC89C5xRC.H>
   4          #include "OneWire.h"
   5          
   6          //DS18B20指令
   7          #define DS18B20_SKIP_ROM 0xCC
   8          #define DS18B20_CONVERT_T 0x44
   9          #define DS18B20_READ_SCRATCHPAD 0xBE
  10          
  11          /**
  12            * @brief  DS18B20开始温度变换
  13            * @param  无
  14            * @retval 无
  15            */
  16          void DS18B20_ConvertT(){
  17   1         OneWire_Init();//单总线初始化
  18   1         OneWire_SendByte(DS18B20_SKIP_ROM);//单总线发送1个字节（跳过ROM指令）
  19   1         OneWire_SendByte(DS18B20_CONVERT_T);//单总线发送1个字节（转换温度指令）
  20   1      }
  21          
  22          /**
  23            * @brief  DS18B20读取温度
  24            * @param  无
  25            * @retval 温度数值
  26            */
  27          float DS18B20_ReadT(){
  28   1         unsigned char TLSB,TMSB;//温度格式
  29   1         int Temp;//临时变量
  30   1         float T;//浮点数温度
  31   1         OneWire_Init();//单总线初始化
  32   1         OneWire_SendByte(DS18B20_SKIP_ROM);//单总线发送1个字节（跳过ROM指令）
  33   1         OneWire_SendByte(DS18B20_READ_SCRATCHPAD);//单总线发送1个字节（转换温度指令）
  34   1         TLSB=OneWire_ReceiveByte();//低8位
  35   1         TMSB=OneWire_ReceiveByte();//高8位
  36   1         Temp=(TMSB<<8)|TLSB;//合并温度16位
  37   1         T=Temp/16.0;//正确转换温度（浮点数）
  38   1         return T;//返回温度值
  39   1      }


