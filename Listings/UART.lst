  16          // 发送单个字符
  17          void UART_SendByte(unsigned char byte) {
  18   1          SBUF = byte;
  19   1          while (TI == 0);    // 等待发送完成
  20   1          TI = 0;             // 清除发送标志
  21   1      }
  22          
  23          // 发送字符串（以'\0'结尾）
  24          void UART_SendString(unsigned char *str) {
  25   1          while (*str != '\0') {
  26   2              UART_SendByte(*str++);
  27   2          }
  28   1      }


