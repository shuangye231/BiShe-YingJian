line level    source

   1          #include <STC89C5xRC.H>
   2          #include "Delay.h"
   3          
   4          //定义引脚
   5          sbit XPT2046_CS=P3^5;
   6          sbit XPT2046_DIN=P3^4;
   7          sbit XPT2046_DCLK=P3^6;
   8          sbit XPT2046_DOUT=P3^7;
   9          
  10          //读取模拟信号转换为数字信号
  11          unsigned int XPT2046_ReadAD(unsigned char Command){//Command模拟信号指令
  12   1         unsigned int ADVAlue=0;//数字信号
  13   1         unsigned char i;//定义循环，右移单位
  14   1         XPT2046_DCLK=0;//低电平
  15   1         XPT2046_CS=0;//低电平
  16   1         for(i=0;i<8;i++){//8位模拟信号的接收
  17   2            XPT2046_DIN=Command&(0x80>>i);//右移，获取当前位/&有0即0
  18   2            XPT2046_DCLK=1;//高电平
  19   2            XPT2046_DCLK=0;//低电平 
  20   2         }
  21   1         for(i=0;i<16;i++){//转换为数字信号
  22   2            XPT2046_DCLK=1;//高电平
  23   2            XPT2046_DCLK=0;//低电平
  24   2            Delay(1);//忙线1ms
  25   2            if(XPT2046_DOUT){ADVAlue|=0x8000>>i;}//右移，赋值当前位/|有1即1
  26   2         }
  27   1         XPT2046_CS=1;//高电平
  28   1         if(Command&0x08){//选择8为输出还是12位输出
  29   2            return ADVAlue>>8;
  30   2         }else{
  31   2            return ADVAlue>>4;
  32   2         }
  33   1         
  34   1      }


