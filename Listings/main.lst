  45   2              LCD_ShowNum(2, 1, adj_value, 4);
  46   2      
  47   2              // 热敏电阻
  48   2              ntc_value = XPT2046_ReadAD(XPT2046_YP_8);
  49   2              LCD_ShowNum(2, 6, ntc_value, 4);
  50   2      
  51   2              // 光敏电阻
  52   2              light_value = XPT2046_ReadAD(XPT2046_VBAT_8);
  53   2              LCD_ShowNum(2, 11, light_value, 4);
  54   2      
