  55   2              // ===================== 3. 亮暗状态判断 =====================
  56   2              if (light_value > 30)
  57   2              {
  58   3                  status = "Light";
  59   3              }
  60   2              else
  61   2              {
  62   3                  status = "Dark";
  63   3              }
